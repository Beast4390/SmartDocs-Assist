# SmartDocs Assistant - Local Enterprise Node Environment Setup
# Copy this file to '.env' and modify configurations as needed.

FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=smartdocs-enterprise-super-secret-key-9988

# Local LLM Service endpoint configurations (Ollama daemon)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama3
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Text chunking configurations
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Semantic Search and LLM parameters
TOP_K=5
TEMPERATURE=0.7

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Maximum upload file size limit in bytes (50MB = 52428800)
MAX_CONTENT_LENGTH=52428800
